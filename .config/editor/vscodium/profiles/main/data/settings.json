{
  "debug.console.fontFamily": "Menlo for Powerline",
  "terminal.integrated.fontFamily": "Inconsolata-g for Powerline",
  "terminal.integrated.fontSize": 14,
  "editor.cursorBlinking": "solid",
  "editor.lineNumbers": "on",
  "vim.useSystemClipboard": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "vim.leader": "SPACE",
  "vim.easymotion": true,
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<leader>",
        "/"
      ],
      "commands": [
        "editor.action.commentLine"
      ]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<leader>",
        "w"
      ],
      "commands": [
        "workbench.action.splitEditor"
      ]
    },
    {
      "before": [
        "<leader>",
        "x"
      ],
      "commands": [
        "workbench.action.closeActiveEditor"
      ]
    },
    {
      "before": [
        "<leader>",
        "f",
        "f"
      ],
      "commands": [
        "workbench.action.quickOpen"
      ]
    },
    {
      "before": [
        "<leader>",
        "c"
      ],
      "commands": [
        "workbench.action.files.newUntitledFile"
      ]
    },
    {
      "before": [
        "<leader>",
        "f",
        "r"
      ],
      "commands": [
        "workbench.action.gotoSymbol"
      ]
    },
    {
      "before": [
        "<leader>",
        "f",
        "m"
      ],
      "commands": [
        "editor.action.formatDocument"
      ]
    },
    {
      "before": [
        "<leader>",
        "/"
      ],
      "commands": [
        "editor.action.commentLine"
      ]
    },
    {
      "before": [
        "g",
        "r"
      ],
      "commands": [
        "editor.action.referenceSearch.trigger"
      ]
    },
    {
      "before": [
        "g",
        "l"
      ],
      "commands": [
        "workbench.action.focusNextGroup"
      ]
    },
    {
      "before": [
        "g",
        "h"
      ],
      "commands": [
        "workbench.action.focusPreviousGroup"
      ]
    }
  ],
  //"editor.fontFamily": "JetBrainsMonoNerdFont,'Cascadia Mono', 'monospace-bold', Inconsolata-g",
  "editor.fontFamily": "'JetBrainsMono Nerd Font', monospace",
  "editor.fontWeight": "bold",
  "editor.fontSize": 16,
  "editor.formatOnPaste": true,
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.snippetSuggestions": "top",
  "editor.renameOnType": true,
  "mdb.defaultLimit": 25,
  "terminal.external.linuxExec": "xterm-256color",
  "terminal.integrated.allowWorkspaceConfiguration": true,
  "terminal.integrated.tabs.enabled": true,
  "git.confirmSync": false,
  "diffEditor.renderSideBySide": false,
  "terminal.external.osxExec": "iTerm.app",
  "editor.cursorStyle": "line",
  "editor.insertSpaces": false,
  "editor.wordSeparators": "/\\()\"':,.;<>~!@#$%^&*|+=[]{}`?-",
  "editor.wordWrap": "off",
  "redhat.telemetry.enabled": false,
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.startupEditor": "none",
  "window.customMenuBarAltFocus": false,
  "files.autoSave": "afterDelay",
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "tabnine.experimentalAutoImports": true,
  "editor.fontLigatures": false,
  "eslint.format.enable": true,
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "git.openRepositoryInParentFolders": "always",
  "editor.copyWithSyntaxHighlighting": false,
  "workbench.editor.empty.hint": "hidden",
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "github.copilot.editor.enableAutoCompletions": true,
  "editor.multiCursorLimit": 20000,
  "tabby.endpoint": "http://0.0.0.0:8080",
  "tabby.config.telemetry": true,
  "editor.inlineSuggest.syntaxHighlightingEnabled": true,
  "supermaven.enable": {
    "*": false
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "CodeGPT.apiKey": "HuggingFace",
  "workbench.colorTheme": "Night Owl",
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "vscode.typescript-language-features",
  "eslint.ignoreUntitled": true,
  "eslint.quiet": true,
  "eslint.run": "onSave",
  "local-sync.autorestore": true,
  "window.menuBarVisibility": "compact",
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "continue.showInlineTip": false,
  "[dotenv]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[ignore]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "yaml.schemas": {
    "/home/robin/.vscode-oss/extensions/continue.continue-1.0.15-linux-x64/config-yaml-schema.json": [
      ".continue/**/*.yaml"
    ]
  },
  "local-sync.backupPath": "/home/robin/.config/codium/",
  "local-sync.ignoreSettings": [],
  "local-sync.ignoreExtensions": [],
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.yarn/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/coverage/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true,
    "**/.cache/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.yarn": true,
    "**/dist": true,
    "**/build": true,
    "**/coverage": true,
    "**/.next": true,
    "**/.turbo": true
  },
  "files.exclude": {
    "**/.DS_Store": true
  },
  "git.ignoreLimitWarning": true,
  "typescript.tsserver.maxTsServerMemory": 4096,
  "typescript.disableAutomaticTypeAcquisition": true
}